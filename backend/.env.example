# Application
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/suvpro
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/suvpro

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
BOT_SECRET=generate-with-python-secrets-token-hex-32

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Yandex Maps
YANDEX_MAPS_API_KEY=your-yandex-maps-key

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
