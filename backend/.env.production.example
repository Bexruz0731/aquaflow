# Production environment — copy to .env and fill in real values

APP_ENV=production
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# PostgreSQL (inside Docker network)
DATABASE_URL=postgresql+asyncpg://postgres:POSTGRES_PASSWORD@postgres:5432/suvpro
DATABASE_SYNC_URL=postgresql://postgres:POSTGRES_PASSWORD@postgres:5432/suvpro

# Redis (inside Docker network) — with password
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_BASE_URL=https://app.suvpro.uz

# File uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# Yandex Maps
YANDEX_MAPS_API_KEY=your-yandex-maps-api-key

# CORS — production domains
ALLOWED_ORIGINS=https://app.suvpro.uz
